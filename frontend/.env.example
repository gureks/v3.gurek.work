# ─── Frontend Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# The .gitignore already excludes .env and .env.*

# ── CLIENT-SIDE (VITE_*) ─────────────────────────────────────────────────────
# These are bundled into the client JS — treat them as PUBLIC values.

# LightRAG server URL — used in local dev only (direct mode).
# In production, the Vercel proxy (/api/query) handles routing instead.
# Development: http://localhost:9621
VITE_API_URL=http://localhost:9621

# Optional: LightRAG static API key for local dev (direct mode).
# In production, the key lives server-side in LIGHTRAG_API_KEY (Vercel dashboard).
# Generate: openssl rand -hex 32
VITE_API_KEY=

# ── SERVER-SIDE (set in Vercel Dashboard → Settings → Environment Variables) ─
# These are NEVER in .env files. They run only inside the /api/query function.
# List them here for documentation purposes only.

# LIGHTRAG_API_URL=https://lrag-gurek.onrender.com  ← LightRAG backend URL
# LIGHTRAG_API_KEY=<same key as LIGHTRAG_API_KEY on the server>
# LIGHTRAG_USERNAME=admin         ← JWT account (AUTH_ACCOUNTS username)
# LIGHTRAG_PASSWORD=<password>    ← JWT account password (bcrypt or plain)

# ─── Security Notes ─────────────────────────────────────────────────────────
# 1. VITE_* vars are bundled into client JS — only put non-sensitive values here
# 2. Real credentials (API key, JWT username/password) go in Vercel Dashboard
# 3. For local dev with full auth: run `vercel dev` (loads Vercel env vars locally)
# 4. For local dev without vercel CLI: set VITE_API_URL + VITE_API_KEY above
